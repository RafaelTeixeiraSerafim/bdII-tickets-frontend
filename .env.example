# TicketsFrontend configuration. Copy to `.env` and adjust as needed.
# All values are optional — the defaults shown reproduce the standard local
# setup (Go API on :8080, Angular dev server on :4200).
#
# Loaded by the Node config scripts (proxy.conf.js, scripts/set-env.js,
# scripts/serve.js). BACKEND_URL/FRONTEND_PORT apply at dev-serve time;
# API_BASE_URL/PRODUCTION are baked into the bundle at build time.

# Backend URL the dev-server proxy forwards "/api" to (dev only).
BACKEND_URL=http://localhost:8080

# Base URL the app uses for API calls. Keep "/api" in dev (uses the proxy);
# set to the API origin for a production build, e.g. https://api.example.com
API_BASE_URL=/api

# Marks the build as production (true|false).
PRODUCTION=false

# Port the Angular dev server listens on.
FRONTEND_PORT=4200
